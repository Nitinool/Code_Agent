# ===== 百炼千问 (Qwen / Dashscope) =====
# 从 https://dashscope.console.aliyun.com/ 获取
DASHSCOPE_API_KEY=sk-xxx
QWEN_API_KEY=sk-xxx

# ===== 智谱清言 (GLM / Zhipu) =====
# 从 https://open.bigmodel.cn/ 获取
ZHIPU_API_KEY=xxx.xxx

# ===== 可选配置 =====
# 默认模型（qwen-plus / qwen-max / qwen-turbo / glm-4-plus / glm-4 / glm-4-flash）
AGENT_MODEL=qwen-plus

# 权限模式：normal（需要确认）/ accept-all（全部自动通过）
AGENT_PERMISSION=normal

# 最大输出 token 数
AGENT_MAX_TOKENS=4096

# 温度（0.0 - 1.0）
AGENT_TEMPERATURE=0.7
