# DeepSeek-V4-Pro 配置（已内置默认值，通常无需修改）

# API Key（如需覆盖内置默认值，取消注释并填入）
# DEEPSEEK_API_KEY=sk-xxxxx

# 模型名（可选，默认 deepseek-v4-pro）
# AGENT_MODEL=deepseek-v4-pro

# Base URL（可选，默认 https://aihub.cixtech.com/v1）
# AGENT_BASE_URL=https://aihub.cixtech.com/v1

# 权限模式：normal（询问）| accept-all（自动放行）
# AGENT_PERMISSION=normal

# 生成参数
# 单次回复最大输出 token 数（默认 16384）
# - 短问答：4096-8192 就够，更快
# - 一般对话：16384（默认）
# - 长文档/大段代码：32768
# - 中文回复尤其耗 token（1 中文 ≈ 1.5-2 token）
# AGENT_MAX_TOKENS=16384
# AGENT_TEMPERATURE=0.7
